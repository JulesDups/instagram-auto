# Copy this file to .env.local and fill in real values.

# === Meta / Instagram Graph API ===
# App ID et App Secret depuis https://developers.facebook.com → ton app → Paramètres → Général
META_APP_ID=
META_APP_SECRET=
# Long-lived page access token (obtenu via me/accounts après échange du token utilisateur)
META_PAGE_ACCESS_TOKEN=
# ID Instagram Business (obtenu via PAGE_ID?fields=instagram_business_account)
IG_BUSINESS_ACCOUNT_ID=

# === Resend ===
RESEND_API_KEY=
EMAIL_FROM=
EMAIL_TO=

# === Webhook intake (Claude.ai → cette app) ===
# Générer avec : node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
INTAKE_SECRET=

# === HMAC pour signer les liens publier/rejeter dans les emails ===
DRAFT_TOKEN_SECRET=

# === Vercel Blob ===
# Provisionné automatiquement par : vercel integration add
BLOB_READ_WRITE_TOKEN=

# === Base URL publique ===
# En local : http://localhost:3000
# En production : https://ton-domaine-vercel.app
PUBLIC_BASE_URL=

# === Dashboard auth ===
# Mot de passe unique pour accéder au dashboard /overview, /queue, /library
DASHBOARD_PASSWORD=

# HMAC secret pour signer le cookie de session (32 bytes hex)
# Générer avec : node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
DASHBOARD_COOKIE_SECRET=

# === Neon Postgres ===
# Provisionné via : neonctl projects create --name instagram-auto
# DATABASE_URL  : pooled connection (used by Prisma at runtime)
# DIRECT_URL    : direct connection (used by Prisma migrate/push)
# TEST_DATABASE_URL : test branch (used by Vitest)
DATABASE_URL="postgres://USER:PASSWORD@HOST-pooler.REGION.aws.neon.tech/DB?sslmode=require"
DIRECT_URL="postgres://USER:PASSWORD@HOST.REGION.aws.neon.tech/DB?sslmode=require"
TEST_DATABASE_URL="postgres://USER:PASSWORD@HOST.REGION.aws.neon.tech/DB?sslmode=require&options=project%3Dtest"
